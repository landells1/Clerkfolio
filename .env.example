# Supabase — find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — find this in your Resend dashboard: API Keys
RESEND_API_KEY=re_your_api_key

# Cron — set a long random secret (min 32 chars), add to Vercel cron headers too
CRON_SECRET=your-cron-secret

# Share link IP pseudonymisation — random secret, independent of other keys
SHARE_IP_HASH_SALT=your-share-ip-hash-salt

# Email one-click unsubscribe token signing (OPTIONAL). If unset it falls back
# to SHARE_IP_HASH_SALT, then CRON_SECRET, so unsubscribe works with no extra
# setup. Set a dedicated random secret to decouple it from those.
UNSUBSCRIBE_SECRET=

# Required in production when exposing the public API; recommended for other routes.
# UI endpoints fall back to in-memory limiting, but public API traffic fails
# closed without a distributed limit.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Canonical app URL
NEXT_PUBLIC_APP_URL=https://clerkfolio.co.uk

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PRICE_ID=price_your_price
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# Sentry — create a project at sentry.io, then Settings → Client Keys for DSN
# VERCEL_ENV is injected into NEXT_PUBLIC_SENTRY_ENVIRONMENT at build time.
# For local builds, set NEXT_PUBLIC_SENTRY_ENVIRONMENT to development or preview.
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_AUTH_TOKEN=sntrys_your_auth_token
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=clerkfolio
