    "@types/papaparse": "^5.5.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "canvas-confetti": "^1.9.4",
    "diff": "^9.0.0",
    "jszip": "^3.10.1",
    "next": "16.2.6",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
