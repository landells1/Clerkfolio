{
  "name": "clerkfolio",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint app components lib",
    "typecheck": "tsc --noEmit",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "scan:secrets:all": "node scripts/scan-secrets.mjs --all",
