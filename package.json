    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
