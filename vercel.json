{
  "regions": ["lhr1"],
  "functions": {
    "app/api/**": {
      "includeFiles": "lib/pdf/portfolio-pdf-runtime.cjs"
    }
  },
  "crons": [
    {
      "path": "/api/cron/notifications",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 6"
    },
    {
      "path": "/api/cron/monthly-digest",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/streak-cache",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/year-in-review",
      "schedule": "0 9 2 1 *"
    },
    {
      "path": "/api/cron/purge-deleted",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/expire-share-links",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/purge-audit-log",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/purge-stale-tokens",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/purge-orphan-uploads",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/referral-vesting",
      "schedule": "0 8 * * *"
    }
  ]
